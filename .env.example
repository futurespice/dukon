# Required — server won't start without this
SECRET_KEY=your-secret-key-here

DEBUG=True
# Production example: ALLOWED_HOSTS=beurer.kg,www.beurer.kg
ALLOWED_HOSTS=*

# CORS (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DB_NAME=dukon_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis
REDIS_URL=redis://localhost:6379/0
# DEVOPS FIX #7: set a strong password in production.
# Production docker-compose.production.yml uses redis://:{REDIS_PASSWORD}@redis:6379/0
# Local dev (docker-compose.yml) can leave this empty.
REDIS_PASSWORD=

# GreenAPI (WhatsApp) — единственный канал доставки кодов — https://green-api.com/
GREENAPI_INSTANCE_ID=your-instance-id
GREENAPI_TOKEN=your-api-token
GREENAPI_BASE_URL=https://api.green-api.com
GREENAPI_REQUEST_TIMEOUT=15

# Employee token TTL (hours). Tokens expire after this many hours.
# Default: 24. Set to 0 to disable TTL (not recommended).
EMPLOYEE_TOKEN_TTL_HOURS=24

# Verification code / 2FA TTL (seconds). Default: 300 (5 min).
VERIFY_CODE_TTL=300
TWO_FA_TTL=300

# Sentry (error tracking) — leave empty to disable
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_RATE=0.1

# DEVOPS FIX #12: configurable gunicorn workers.
# Recommended: 2 × vCPU + 1. Defaults to 4 if not set.
GUNICORN_WORKERS=4

# DEVOPS FIX #8: backup configuration (used by scripts/backup.sh)
# BACKUP_DIR=/var/backups/dukon
# BACKUP_KEEP_DAYS=7
# S3_BUCKET=s3://your-bucket/dukon-backups
